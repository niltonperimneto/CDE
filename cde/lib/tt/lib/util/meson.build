  join_paths(tt_util_dir, 'tt_trace_stream.C'),
  join_paths(tt_util_dir, 'tt_tracefile_parse.C'),
  join_paths(tt_util_dir, 'tt_xdr_utils.C'),
]

libtt_util = static_library('tt_util',
  libtt_util_sources,
  include_directories : [inc, tt_inc, include_directories('../../../..')],
  dependencies : dep_tirpc,
  pic : true
)
