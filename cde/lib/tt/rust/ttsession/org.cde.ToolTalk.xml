<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
    "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<!--
  D-Bus introspection for the CDE ToolTalk session broker.

  Bus name  : org.cde.ToolTalk
  Object    : /org/cde/ToolTalk
  Served by : ttsession (Rust, zbus 5)

  This file documents the interface for tooling and static analysis.
  zbus generates a live introspection response automatically; this XML
  exists so that tools like d-feet, qdbus, or gdbus-codegen can work
  with the interface without requiring a running broker.

  Argument encoding for a(sss) (mode/vtype/value triples)
  ──────────────────────────────────────────────────────────
  Each element of an arg array is a D-Bus struct (sss):

    mode   │ "in"     │ TT_IN   (input to handler)
           │ "out"    │ TT_OUT  (output from handler)
           │ "inout"  │ TT_INOUT
    ───────┼──────────┼────────────────────────────
    vtype  │ "int"    │ value is a decimal i32
           │ "string" │ value is UTF-8 text
           │ "bytes"  │ value is lowercase hex-encoded bytes
-->
<node name="/org/cde/ToolTalk">

  <interface name="org.cde.ToolTalk">

    <!--
      SendMessage — deliver a ToolTalk message to the broker.

      The broker:
        1. Looks up registered ptypes whose signatures match (op, scope).
        2. Auto-starts processes whose action is "Start".
        3. Emits MessageDelivered so all observers receive the message.
        4. Returns TT_OK (0) or a negative TT_ERR_* error code.

      Scope values:
        1 = session scope (broadcast to all session participants)
        2 = file scope    (targeted to handlers for a specific file)
    -->
    <method name="SendMessage">
      <arg name="op"     type="s"      direction="in"/>
      <arg name="args"   type="a(sss)" direction="in"/>
      <arg name="scope"  type="i"      direction="in"/>
      <arg name="file"   type="s"      direction="in"/>
      <arg name="status" type="i"      direction="out"/>
    </method>

    <!--
      MessageDelivered — broadcast signal emitted after SendMessage dispatch.

      All clients that have registered a D-Bus match rule for this signal
      receive a copy.  The typical match rule (in pseudo-notation) is:

        type='signal',
        interface='org.cde.ToolTalk',
        member='MessageDelivered'

      "sender" is the D-Bus unique name (:1.N) of the process that called
      SendMessage, not the ToolTalk procid.
    -->
    <signal name="MessageDelivered">
      <arg name="op"     type="s"/>
      <arg name="args"   type="a(sss)"/>
      <arg name="scope"  type="i"/>
      <arg name="file"   type="s"/>
      <arg name="sender" type="s"/>
    </signal>

    <!--
      Ping — health-check; returns "Pong".

      Use this to verify the broker is alive without side effects:
        busctl --user call org.cde.ToolTalk /org/cde/ToolTalk \
               org.cde.ToolTalk Ping
    -->
    <method name="Ping">
      <arg name="pong" type="s" direction="out"/>
    </method>

    <!--
      ListPtypes — return names of all loaded process types.

      Useful for debugging ptype loading:
        busctl --user call org.cde.ToolTalk /org/cde/ToolTalk \
               org.cde.ToolTalk ListPtypes
    -->
    <method name="ListPtypes">
      <arg name="ptypes" type="as" direction="out"/>
    </method>

  </interface>

  <!-- Standard D-Bus interfaces are implemented automatically by zbus. -->
  <interface name="org.freedesktop.DBus.Introspectable">
    <method name="Introspect">
      <arg name="xml_data" type="s" direction="out"/>
    </method>
  </interface>

  <interface name="org.freedesktop.DBus.Peer">
    <method name="Ping"/>
    <method name="GetMachineId">
      <arg name="machine_uuid" type="s" direction="out"/>
    </method>
  </interface>

  <interface name="org.freedesktop.DBus.Properties">
    <method name="Get">
      <arg name="interface_name"  type="s" direction="in"/>
      <arg name="property_name"   type="s" direction="in"/>
      <arg name="value"           type="v" direction="out"/>
    </method>
    <method name="GetAll">
      <arg name="interface_name" type="s"  direction="in"/>
      <arg name="props"          type="a{sv}" direction="out"/>
    </method>
    <method name="Set">
      <arg name="interface_name" type="s" direction="in"/>
      <arg name="property_name"  type="s" direction="in"/>
      <arg name="value"          type="v" direction="in"/>
    </method>
    <signal name="PropertiesChanged">
      <arg name="interface_name"  type="s"/>
      <arg name="changed_properties"   type="a{sv}"/>
      <arg name="invalidated_properties" type="as"/>
    </signal>
  </interface>

</node>
